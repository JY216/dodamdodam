<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="dev.yeonlog.dodamdodam.mappers.UserMapper">
    <insert id="insert" parameterType="dev.yeonlog.dodamdodam.entities.UserEntity">
        INSERT INTO `users` (`user_id`, `password`, `name`, `email`, `birth`, `gender`, `role`, `status`, `address_primary`, `address_secondary`, `mobile_first`, `mobile_second`, `mobile_third`)
        VALUES (#{userId}, #{password}, #{name}, #{email}, #{birth}, #{gender},
                #{role}, #{status}, #{addressPrimary}, #{addressSecondary}, #{mobileFirst}, #{mobileSecond}, #{mobileThird})
    </insert>
    <select id="selectByUserId" resultType="dev.yeonlog.dodamdodam.entities.UserEntity">
        SELECT `user_id`,
               `password`,
               `name`,
               `email`,
               `birth`,
               `gender`,
               `role`,
               `status`,
               `address_primary`,
               `address_secondary`,
               `mobile_first`,
               `mobile_second`,
               `mobile_third`,
               `created_at`,
               `updated_at`,
               `overdue`,
               `overcnt`
        FROM `dodamdodam`.`users`
        WHERE `user_id` = #{userId}
        LIMIT 1
    </select>
</mapper>