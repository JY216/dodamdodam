<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="dev.yeonlog.dodamdodam.mappers.UserStatusMapper">
    <update id="updateStatus">
        UPDATE `dodamdodam`.`users`
        SET `status` = #{status}
        WHERE `user_id` = #{userId}
    </update>

    <select id="findStatusByUserId" resultType="java.lang.String">
        SELECT `status`
        FROM `dodamdodam`.`users`
        WHERE `user_id` = #{userId}
    </select>
</mapper>