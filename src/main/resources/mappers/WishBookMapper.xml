<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="dev.yeonlog.dodamdodam.mappers.WishBookMapper">
<!--    희망 도서 신청-->
    <insert id="insertWishBook" parameterType="dev.yeonlog.dodamdodam.entities.WishBookEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `dodamdodam`.`wish_books` (`user_id`,
                                               `title`,
                                               `author`,
                                               `publisher`,
                                               `publish_year`,
                                               `isbn`,
                                               `price`,
                                               `reason`)
        VALUES (#{userId},
                #{title},
                #{author},
                #{publisher},
                #{publishYear},
                #{isbn},
                #{price},
                #{reason})
    </insert>
    <!--    유저 - 내 신청 목록-->
    <select id="selectByUserId" resultType="dev.yeonlog.dodamdodam.entities.WishBookEntity">
        SELECT `id`,
               `user_id`,
               `title`,
               `author`,
               `publisher`,
               `publish_year`,
               `isbn`,
               `price`,
               `reason`,
               `status`,
               `created_at`
        FROM `dodamdodam`.`wish_books`
        WHERE `user_id` = #{userId}
        ORDER BY `created_at` DESC
    </select>
<!--    관리자 - 전체 신청 목록-->
    <select id="selectAllWishBooks" resultType="dev.yeonlog.dodamdodam.entities.WishBookEntity">
        SELECT w.`id`,
               w.`user_id`,
               w.`title`,
               w.`author`,
               w.`publisher`,
               w.`publish_year`,
               w.`isbn`,
               w.`price`,
               w.`reason`,
               w.`status`,
               w.`created_at`,
               u.`name` AS `user_name`
        FROM `dodamdodam`.`wish_books` AS w
        LEFT JOIN `dodamdodam`.`users` AS u ON w.`user_id` = u.`user_id`
        ORDER BY w.`created_at` DESC
    </select>
    <!--    관리자 - 상태 변경-->
    <update id="updateStatus">
        UPDATE `dodamdodam`.`wish_books`
        SET `status` = #{status}
        WHERE `id` = #{id}
    </update>

    <select id="selectAllWishBooksWithPage" resultType="dev.yeonlog.dodamdodam.entities.WishBookEntity">
        SELECT w.*, u.`name` AS `user_name`
        FROM `dodamdodam`.`wish_books` w
                 LEFT JOIN `dodamdodam`.`users` u ON w.`user_id` = u.`user_id`
        ORDER BY w.`created_at` DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>
    <select id="countAllWishBooks" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM `dodamdodam`.`wish_books`
    </select>
</mapper>